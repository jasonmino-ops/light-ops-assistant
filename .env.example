# ── 数据库连接（必填）────────────────────────────────────────────────────────
#
# DATABASE_URL  → 运行时连接（Prisma Client 查询）
#   使用 Supabase Transaction-mode pooler（端口 6543）
#   高并发 serverless 环境（如 Vercel）适合此模式
#   格式：postgresql://USER:PASSWORD@HOST:6543/DB_NAME?sslmode=require
#
# DIRECT_URL    → 迁移专用（prisma migrate deploy / db push）
#   使用 Supabase 直连（端口 5432，绕过 pooler）
#   advisory lock 需要真实 session，pooler 不支持，必须走直连
#   格式：postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
#
# 两个 URL 的 USER / PASSWORD / DB_NAME 相同，只有 HOST 和 PORT 不同：
#   pooler host  示例：aws-0-ap-southeast-1.pooler.supabase.com  port 6543
#   direct host  示例：db.xxxxxxxxxxxx.supabase.co               port 5432
#
# Supabase 控制台获取路径：
#   Project Settings → Database → Connection string
#     "Transaction pooling"  → DATABASE_URL
#     "Direct connection"    → DIRECT_URL
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/DB_NAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/DB_NAME?sslmode=require"

# ── Session 签名密钥（必填，生产必须换成随机长字符串）──────────────────────────
# 用于签名 auth-session cookie，防止伪造
# 生成示例：openssl rand -hex 32
AUTH_SECRET="change-me-to-a-random-32-char-string"

# ── Telegram Bot Token（生产必填）────────────────────────────────────────────
# 从 @BotFather 获取，用于验证 WebApp initData 的 HMAC 签名
# 留空时跳过签名验证（仅限本地开发调试）
TELEGRAM_BOT_TOKEN=""

# ── 租户 ID（与数据库种子一致）───────────────────────────────────────────────
# 该 Bot 所服务的租户，默认使用种子数据的 seed-tenant-001
TENANT_ID="seed-tenant-001"

# ── Telegram Bot 用户名（用于生成邀请深链）────────────────────────────────────
# @BotFather → /mybots → 你的 bot 用户名（不带 @）
# 用于生成 https://t.me/<bot>?startapp=bind_<token> 格式的邀请链接
# 应为商户 bot（merchant bot），不是 ops bot
TELEGRAM_BOT_USERNAME=""

# ── 开发期角色切换（本地 dev 专用，生产不生效）────────────────────────────────
# 无 Telegram WebApp 时的身份模拟：
#   STAFF → 首页 /home，底部导航：首页/销售/退款/记录
#   OWNER → 首页 /dashboard，底部导航：首页/销售/退款/记录/概览
DEV_ROLE=STAFF
