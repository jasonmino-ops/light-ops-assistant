generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  STAFF
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum StoreStatus {
  ACTIVE
  DISABLED
}

enum ProductStatus {
  ACTIVE
  DISABLED
}

enum MarketingProductPageStatus {
  DRAFT
  PUBLISHED
  DISABLED
}

enum MarketingProductPageTemplateType {
  TIKTOK_HOT
  HOME_GOODS
  FOOD_SET
  BEAUTY
}

enum SaleType {
  SALE
  REFUND
}

enum RecordStatus {
  PENDING_PAYMENT  // 已建单，待收款（零售 KHQR 挂单 / 未来餐饮预留）
  COMPLETED        // 已完成（含收款确认）
  CANCELLED        // 已取消（含 KHQR 超时/主动取消）
}

enum PaymentMethod {
  CASH
  KHQR
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum LogStatus {
  SUCCESS
  FAILED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ACTIVE")
  tier      String   @default("LITE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores      Store[]
  users       User[]
  products    Product[]
  marketingProductPages MarketingProductPage[]
  sales       SaleRecord[]
  logs        OperationLog[]
  bindTokens  BindToken[]
}

model Store {
  id           String      @id @default(cuid())
  tenantId     String
  code         String      @unique
  name         String
  status       StoreStatus @default(ACTIVE)
  checkoutMode String      @default("DIRECT_PAYMENT") // DIRECT_PAYMENT | DEFERRED_PAYMENT
  businessType String      @default("GENERAL")        // FOOD | RETAIL | SERVICE | GENERAL
  bannerUrl         String?                           // 顾客页头图访问 URL（指向内部图片端点）
  bannerData        String?   @db.Text               // 头图 base64 数据（data:image/...;base64,...）
  announcement      String?                          // 公告文本
  promoText         String?                          // 活动文案
  eLifeFeatured     Boolean   @default(false)        // E-Life 首页「为你推荐」运营位
  eLifeFeaturedSort Int       @default(0)            // 推荐排序，数字越小排越前
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  userRoles      UserStoreRole[]
  sales          SaleRecord[]
  logs           OperationLog[]
  bindTokens     BindToken[]
  campaignLinks  CampaignLink[]
  creators       Creator[]
  marketingProductPages MarketingProductPage[]

  @@index([tenantId])
}

model User {
  id          String     @id @default(cuid())
  tenantId    String
  username    String
  displayName String
  role        UserRole
  status      UserStatus @default(ACTIVE)
  telegramId  String?
  staffNumber Int?       // null for OWNER; sequential (1,2,3…) for STAFF within tenant
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  storeRoles UserStoreRole[]
  sales      SaleRecord[]
  logs       OperationLog[]

  @@unique([tenantId, username])
  @@index([tenantId])
}

model UserStoreRole {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  storeId   String
  role      UserRole
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@index([tenantId])
  @@index([storeId])
}

model ProductCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  parentId  String?  // null = 一级分类；non-null = 二级分类
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([tenantId])
  @@index([tenantId, parentId])
}

model Product {
  id         String        @id @default(cuid())
  tenantId   String
  barcode    String
  sku        String?
  name       String
  spec       String?
  sellPrice  Decimal       @db.Decimal(12, 2)
  status     ProductStatus @default(ACTIVE)
  categoryId String?
  nameZh     String?
  nameEn     String?
  nameKm     String?
  descZh     String?
  descEn     String?
  descKm     String?
  imageUrl        String?    // 商品主图公开访问 URL（Supabase Storage public bucket）
  imageStorageKey String?    // Storage 对象 key，用于删除/替换
  imageUrls       String?    @db.Text // JSON: 最多 3 张商品图 URL；第一张同步到 imageUrl
  imageStorageKeys String?   @db.Text // JSON: 与 imageUrls 对应的 Storage object keys
  imageUpdatedAt  DateTime?  // 图片最近一次更新时间
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  category ProductCategory? @relation(fields: [categoryId], references: [id])
  sales    SaleRecord[]
  marketingProductPages MarketingProductPage[]

  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([name])
  @@index([categoryId])
}

model MarketingProductPage {
  id           String                     @id @default(cuid())
  tenantId     String
  storeId      String
  productId    String
  slug         String                     @unique
  status       MarketingProductPageStatus @default(DRAFT)
  templateType MarketingProductPageTemplateType?
  title        String?
  titleZh      String?
  titleEn      String?
  titleKm      String?
  subtitle     String?
  heroImageUrl String?
  heroVideoUrl String?
  salePrice    Decimal?                   @db.Decimal(12, 2)
  originalPrice Decimal?                  @db.Decimal(12, 2)
  soldCount    Int?
  feature1     String?
  feature2     String?
  feature3     String?
  feature4     String?
  feature5     String?
  feature1Zh   String?
  feature2Zh   String?
  feature3Zh   String?
  feature4Zh   String?
  feature5Zh   String?
  feature1En   String?
  feature2En   String?
  feature3En   String?
  feature4En   String?
  feature5En   String?
  feature1Km   String?
  feature2Km   String?
  feature3Km   String?
  feature4Km   String?
  feature5Km   String?
  enableCountdown Boolean                 @default(false)
  detailImage1 String?
  detailImage2 String?
  detailImage3 String?
  reviewImage1 String?
  reviewImage2 String?
  reviewImage3 String?
  buttonText   String?
  buttonTextZh String?
  buttonTextEn String?
  buttonTextKm String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([storeId])
  @@index([productId])
}

model SaleRecord {
  id             String @id @default(cuid())
  tenantId       String
  storeId        String
  operatorUserId String

  recordNo String       @unique
  saleType SaleType
  status   RecordStatus @default(COMPLETED)

  productId           String?
  barcode             String
  productNameSnapshot String
  specSnapshot        String?
  unitPrice           Decimal @db.Decimal(12, 2)
  quantity            Decimal @db.Decimal(12, 2)
  lineAmount          Decimal @db.Decimal(12, 2)

  orderNo              String?  // 一次结账所有明细行共享此单号；null = 历史单行记录

  originalSaleRecordId String?
  refundedQty          Decimal? @db.Decimal(12, 2)
  refundReason         String?
  remark               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  store        Store    @relation(fields: [storeId], references: [id])
  operatorUser User     @relation(fields: [operatorUserId], references: [id])
  product      Product? @relation(fields: [productId], references: [id])

  originalSaleRecord SaleRecord?  @relation("RefundRelation", fields: [originalSaleRecordId], references: [id])
  refundChildren     SaleRecord[] @relation("RefundRelation")

  logs OperationLog[]

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([operatorUserId, createdAt])
  @@index([saleType, createdAt])
  @@index([originalSaleRecordId])
  @@index([barcode])
}

model MerchantPaymentConfig {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String?                    // null = tenant 级默认配置
  provider           String   @default("BAKONG_KHQR") // BAKONG_KHQR | ...
  merchantId         String?                    // null = 纯图片模式
  merchantName       String?                    // null = 纯图片模式
  merchantAccountRef String?                    // null = 纯图片模式；Bakong 账户手机号 / ref
  currency           String   @default("USD")   // USD | KHR
  khqrEnabled        Boolean  @default(true)
  isDefault          Boolean  @default(false)
  isActive           Boolean  @default(true)
  khqrImageUrl       String?  @db.Text          // base64 data URL (老板通过 Telegram 上传)
  uploadedByUserId   String?                    // 上传者 User.id
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  paymentIntents PaymentIntent[]

  @@index([tenantId])
  @@index([tenantId, storeId])
}

model PaymentIntent {
  id               String        @id @default(cuid())
  tenantId         String
  storeId          String
  operatorUserId   String
  orderNo          String        @unique
  paymentMethod    PaymentMethod
  status           PaymentStatus @default(PENDING)
  amount           Decimal       @db.Decimal(12, 2)
  khqrPayload      String?       // EMV QR string; null for CASH
  provider         String?       // from MerchantPaymentConfig.provider
  merchantConfigId String?       // FK to MerchantPaymentConfig
  paidAt           DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  merchantConfig MerchantPaymentConfig? @relation(fields: [merchantConfigId], references: [id])

  @@index([tenantId, createdAt])
  @@index([orderNo])
  @@index([status])
  @@index([merchantConfigId])
}

model BindToken {
  id        String   @id @default(cuid())
  token     String   @unique
  tenantId  String
  storeId   String
  role      UserRole
  label     String?          // 人工备注，如"总店员工邀请"
  expiresAt DateTime
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  status    String   @default("ACTIVE") // ACTIVE | REVOKED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId], references: [id])

  @@index([tenantId])
  @@index([token])
}

model OperationLog {
  id       String  @id @default(cuid())
  tenantId String
  storeId  String?
  userId   String?

  actionType      String
  targetType      String
  targetId        String?
  requestId       String?
  status          LogStatus
  message         String?
  payloadSnapshot Json?
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store? @relation(fields: [storeId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  saleRecordId String?
  saleRecord   SaleRecord? @relation(fields: [saleRecordId], references: [id])

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([userId, createdAt])
  @@index([requestId])
}

model TenantDailySummary {
  id           String   @id @default(cuid())
  date         String   // YYYY-MM-DD (UTC)
  tenantId     String
  salesCount   Int      @default(0)
  refundCount  Int      @default(0)
  grossSales   Decimal  @default(0) @db.Decimal(12, 2)
  refundAmount Decimal  @default(0) @db.Decimal(12, 2)
  netSales     Decimal  @default(0) @db.Decimal(12, 2)
  computedAt   DateTime @default(now())

  @@unique([tenantId, date])
  @@index([date])
}

model StoreDailySummary {
  id           String   @id @default(cuid())
  date         String   // YYYY-MM-DD (UTC)
  tenantId     String
  storeId      String
  salesCount   Int      @default(0)
  refundCount  Int      @default(0)
  grossSales   Decimal  @default(0) @db.Decimal(12, 2)
  refundAmount Decimal  @default(0) @db.Decimal(12, 2)
  netSales     Decimal  @default(0) @db.Decimal(12, 2)
  computedAt   DateTime @default(now())

  @@unique([storeId, date])
  @@index([tenantId, date])
}

model StoreApplication {
  id               String    @id @default(cuid())
  storeName        String
  ownerName        String
  telegramId       String
  telegramUsername String?
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt        DateTime  @default(now())
  approvedAt       DateTime?
  tenantId         String?   // set on approval
  bindTokenValue   String?   // set on approval, mirrors BindToken.token
  note             String?

  @@index([status])
  @@index([telegramId])
}

model TelegramMessage {
  id                  String   @id @default(cuid())
  tenantId            String?           // null = ops/系统级消息
  recipientTelegramId String            // 发件方(CUSTOMER)或收件方(OPS/SYSTEM)的 TG ID
  senderName          String?           // 客户名称，CUSTOMER 消息时填入
  messageType         String   @default("TEXT") // TEXT | IMAGE | STICKER | VOICE | VIDEO | FILE | OTHER
  content             String
  status              String   @default("SENT") // SENT | FAILED | RECEIVED
  errorMessage        String?
  sentBy              String   @default("SYSTEM") // SYSTEM | OPS | CUSTOMER
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@index([recipientTelegramId])
  @@index([createdAt])
}

model ProductImportSession {
  telegramId  String   @id
  tenantId    String?
  phase       String   @default("AWAITING_DATA") // AWAITING_DATA | AWAITING_CONFIRM
  pendingRows String   @default("[]")            // JSON — TgImportRow[]
  updatedAt   DateTime @updatedAt
}

model CustomerOrder {
  id                 String    @id @default(cuid())
  tenantId           String
  storeId            String
  storeCode          String
  orderNo            String    @unique
  customerTelegramId String?           // null = 匿名；可后续由顾客绑定 TG 后回填
  customerLang       String?           // 顾客下单时的 H5 语言：zh | en | km；通知顾客时使用
  customerName       String?           // 配送/上门订单：联系人姓名（可选）
  customerPhone      String?           // 配送/上门订单：联系电话（delivery 必填）
  deliveryAddress    String?   @db.Text// 配送/上门订单：详细地址（delivery 必填）
  deliveryNote       String?   @db.Text// 门牌/楼层/备注
  deliveryLat        Float?            // 定位纬度（可选）
  deliveryLng        Float?            // 定位经度（可选）
  deliveryAddressPhotoUrl  String?              // 门牌/位置照片对外可点击的 URL（通常指向内部 GET 端点）
  deliveryAddressPhotoData String?    @db.Text  // 门牌/位置照片 base64 data URL（与上字段配套；由内部端点读取返回二进制）
  itemsJson          String    @db.Text // JSON: [{productId,name,spec,price,quantity,lineAmount}]
  totalAmount        Decimal   @db.Decimal(12, 2)
  status             String    @default("PENDING") // PENDING | CONFIRMED | COMPLETED | CANCELLED
  remark             String?
  paymentStatus      String    @default("UNPAID")  // UNPAID | PAID
  paymentMethod      String?                        // CASH | QR
  paidAt             DateTime?
  paidAmount         Decimal?  @db.Decimal(12, 2)
  tableNo            String?                        // 餐饮桌号，URL table= 参数传入，null = 外卖/自取
  sourcePlatform     String?                        // 推广来源平台，如 tiktok
  campaignCode       String?                        // 短链 code，对应 CampaignLink.code
  campaignLinkId     String?                        // 关联 CampaignLink.id
  campaignIntent     String?                        // order | menu
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([orderNo])
  @@index([campaignLinkId])
}

model KhqrConfigSession {
  telegramId String   @id
  tenantId   String?
  phase      String   @default("AWAITING_IMAGE") // AWAITING_IMAGE | AWAITING_CONFIRM
  fileId     String?                              // Telegram file_id，确认时下载转 base64
  updatedAt  DateTime @updatedAt
}

model SupportSession {
  telegramId   String   @id
  tenantId     String?
  sessionState String   @default("auto_active") // auto_active | awaiting_human | human_active
  language     String   @default("zh")           // zh | en | km
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([sessionState])
}

model AiSupportProviderConfig {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String?
  provider           String
  enabled            Boolean  @default(false)
  apiBaseUrl         String?
  clientId           String?
  encryptedApiSecret String?
  secretRef          String?
  allowedToolsJson   String   @default("[]") @db.Text
  timeoutMs          Int      @default(3000)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([provider])
  @@unique([tenantId, storeId, provider])
}

model AiSupportAuditLog {
  id              String   @id @default(cuid())
  tenantId        String?
  storeId         String?
  customerId      String?
  sessionId       String?
  provider        String
  userMessage     String   @db.Text
  aiReply         String?  @db.Text
  intent          String?
  confidence      Float?
  needHuman       Boolean?
  toolCallsJson   String?  @db.Text
  providerAuditId String?
  latencyMs       Int?
  status          String
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([customerId, createdAt])
  @@index([sessionId, createdAt])
  @@index([provider, createdAt])
  @@index([status, createdAt])
}

model OpsAdmin {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String?  // scrypt hash; null = password login disabled
  telegramId   String?  @unique
  role         String   @default("OPS_ADMIN") // SUPER_ADMIN | OPS_ADMIN | BD
  status       String   @default("ACTIVE")    // ACTIVE | DISABLED
  sessionVersion   Int      @default(0)   // bump 后旧 session 失效（被盗 cookie 强制下线）
  failedLoginCount Int      @default(0)   // 连续登录失败次数（成功后清零）
  lockedUntil      DateTime?              // 账号锁定到期时间（5 次失败锁 15 分钟）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 顾客下单后通过 /start bind_<storeCode>_<orderNo> 主动绑定 Telegram，沉淀为门店常驻联系人
model StoreCustomerContact {
  id                   String   @id @default(cuid())
  tenantId             String?
  storeCode            String
  telegramId           String
  telegramUsername     String?
  telegramFirstName    String?
  telegramLastName     String?
  telegramLanguageCode String?
  lastOrderId          String?
  source               String   @default("telegram_bind_after_order")
  status               String   @default("active") // active | flagged（OPS 标记异常） | revoked（OPS 解除绑定）
  opsNote              String?  @db.Text           // OPS 后台维护备注（不对老板端展示）
  firstBoundAt         DateTime @default(now())
  lastSeenAt           DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([storeCode, telegramId])
  @@index([tenantId])
  @@index([storeCode])
  @@index([telegramId])
}

// 商户单顾客 Telegram 触达日志
// - 由 /customers 页 OWNER 主动触发，模板化（THANK_YOU / PROMO / ORDER_CARE）
// - 走 CUSTOMER_BOT_TOKEN 发送，不串商户 bot / OPS bot
// - 24h 同顾客同模板节流由应用层在 API 中查询本表实现
model CustomerTouchLog {
  id           String   @id @default(cuid())
  tenantId     String
  storeId      String?
  telegramId   String
  templateKey  String   // THANK_YOU | PROMO | ORDER_CARE
  messageText  String   @db.Text
  status       String   // SENT | FAILED | THROTTLED
  errorMessage String?
  sentByUserId String
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([tenantId, telegramId, sentAt])
  @@index([sentByUserId])
}

// ─── 优惠券（v1 最小闭环） ───────────────────────────────────────────────
//
// 数据底座由 Supabase SQL Editor 手动建表（见 docs/db/COUPON_TABLES_DDL.md），
// 不走 prisma migrate；本 schema 仅声明 model 供 Prisma Client 类型使用。

enum CouponType {
  AMOUNT_OFF
  PERCENT_OFF
}

enum CouponTemplateStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DELETED
}

enum CustomerCouponStatus {
  AVAILABLE
  USED
  EXPIRED
  CANCELLED
}

model CouponTemplate {
  id            String               @id @default(cuid())
  tenantId      String
  storeId       String?              // null 表示全租户通用
  name          String
  type          CouponType           @default(AMOUNT_OFF)
  amountOff     Decimal?             @db.Decimal(10, 2) // AMOUNT_OFF 必填
  percentOff    Int?                 // PERCENT_OFF 必填，1~99
  minSpend      Decimal              @default(0) @db.Decimal(10, 2)
  validDays     Int                  @default(7)        // 自发放起 N 天过期
  status        CouponTemplateStatus @default(ACTIVE)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  coupons       CustomerCoupon[]
  batches       CouponIssueBatch[]

  @@index([tenantId, status])
}

model CustomerCoupon {
  id           String                @id @default(cuid())
  tenantId     String
  storeId      String?               // 仅限该门店使用；null = 全租户通用
  templateId   String
  telegramId   String                // 顾客主键（与 StoreCustomerContact 一致）
  status       CustomerCouponStatus  @default(AVAILABLE)
  // 发放时的快照（避免模板后续修改影响已发放券）
  name         String
  type         CouponType
  amountOff    Decimal?              @db.Decimal(10, 2)
  percentOff   Int?
  minSpend     Decimal               @default(0) @db.Decimal(10, 2)
  expiresAt    DateTime
  usedAt       DateTime?
  usedOrderNo  String?
  batchId      String?
  issuedByUserId String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  template     CouponTemplate        @relation(fields: [templateId], references: [id])
  redemptions  CouponRedemption[]

  @@index([tenantId, telegramId, status])
  @@index([tenantId, storeId, telegramId, status])
  @@index([batchId])
}

model CouponRedemption {
  id             String   @id @default(cuid())
  tenantId       String
  storeId        String
  couponId       String
  telegramId     String
  orderNo        String
  discountAmount Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  coupon         CustomerCoupon @relation(fields: [couponId], references: [id])

  @@unique([orderNo])
  @@index([tenantId, storeId, createdAt])
  @@index([couponId])
}

model CouponIssueBatch {
  id            String   @id @default(cuid())
  tenantId      String
  storeId       String?
  templateId    String
  issuedByUserId String
  totalCount    Int      @default(0)
  successCount  Int      @default(0)
  failedCount   Int      @default(0)
  createdAt     DateTime @default(now())

  template      CouponTemplate @relation(fields: [templateId], references: [id])

  @@index([tenantId, createdAt])
}

// ─── 顾客 bot 三层对话日志（阶段一） ─────────────────────────────────────
// 数据底座由 Supabase SQL Editor 手动建表：docs/db/CONVERSATION_LOG_DDL.md
model ConversationLog {
  id           String   @id @default(cuid())
  tenantId     String?
  storeCode    String?
  telegramId   String
  lang         String?      // zh | en | km
  direction    String       // IN | OUT
  text         String   @db.Text
  intentLayer  Int?
  intentSlot   String?
  intentSource String?      // RISK | BIZ | CHAT | FALLBACK_SHORT | FALLBACK_UNKNOWN | VOICE | RATE_LIMIT
  escalated    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([telegramId, createdAt])
  @@index([tenantId, createdAt])
}

// ─── TikTok / 社交媒体推广短链 ────────────────────────────────────────────
model CampaignLink {
  id               String    @id @default(cuid())
  code             String    @unique
  storeId          String
  sourcePlatform   String    @default("tiktok")
  creatorId        String?
  creatorName      String?                         // 兼容旧数据或临时手填博主名
  videoTitle       String?
  targetUrl        String
  status           String    @default("ACTIVE")    // ACTIVE | PAUSED
  viewCount        Int       @default(0)
  clickCount       Int       @default(0)
  commissionType   String?                         // percent | fixed
  commissionValue  Decimal?  @db.Decimal(10, 2)
  settlementStatus String    @default("unsettled") // unsettled | settled
  settledAt        DateTime?
  settledNote      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  store            Store     @relation(fields: [storeId], references: [id])
  creator          Creator?  @relation(fields: [creatorId], references: [id])

  @@index([storeId])
  @@index([status])
  @@index([creatorId])
}

model Creator {
  id            String   @id @default(cuid())
  tenantId      String
  storeId       String
  name          String
  displayName   String?
  phone         String?
  telegramId    String?
  tiktokHandle  String?
  note          String?
  status                  String    @default("active") // active | inactive
  preferredLang           String?                      // zh | en | km
  dashboardToken          String?   @unique
  dashboardTokenCreatedAt DateTime?
  dashboardTokenRevokedAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  store          Store          @relation(fields: [storeId], references: [id])
  campaignLinks  CampaignLink[]

  @@index([storeId])
  @@index([tenantId])
}
