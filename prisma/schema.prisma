generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  STAFF
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum StoreStatus {
  ACTIVE
  DISABLED
}

enum ProductStatus {
  ACTIVE
  DISABLED
}

enum SaleType {
  SALE
  REFUND
}

enum RecordStatus {
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  KHQR
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum LogStatus {
  SUCCESS
  FAILED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ACTIVE")
  tier      String   @default("LITE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores      Store[]
  users       User[]
  products    Product[]
  sales       SaleRecord[]
  logs        OperationLog[]
  bindTokens  BindToken[]
}

model Store {
  id        String      @id @default(cuid())
  tenantId  String
  code      String      @unique
  name      String
  status    StoreStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  userRoles   UserStoreRole[]
  sales       SaleRecord[]
  logs        OperationLog[]
  bindTokens  BindToken[]

  @@index([tenantId])
}

model User {
  id          String     @id @default(cuid())
  tenantId    String
  username    String
  displayName String
  role        UserRole
  status      UserStatus @default(ACTIVE)
  telegramId  String?
  staffNumber Int?       // null for OWNER; sequential (1,2,3…) for STAFF within tenant
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  storeRoles UserStoreRole[]
  sales      SaleRecord[]
  logs       OperationLog[]

  @@unique([tenantId, username])
  @@index([tenantId])
}

model UserStoreRole {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  storeId   String
  role      UserRole
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@index([tenantId])
  @@index([storeId])
}

model Product {
  id        String        @id @default(cuid())
  tenantId  String
  barcode   String
  sku       String?
  name      String
  spec      String?
  sellPrice Decimal       @db.Decimal(12, 2)
  status    ProductStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  sales  SaleRecord[]

  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([name])
}

model SaleRecord {
  id             String @id @default(cuid())
  tenantId       String
  storeId        String
  operatorUserId String

  recordNo String       @unique
  saleType SaleType
  status   RecordStatus @default(COMPLETED)

  productId           String?
  barcode             String
  productNameSnapshot String
  specSnapshot        String?
  unitPrice           Decimal @db.Decimal(12, 2)
  quantity            Decimal @db.Decimal(12, 2)
  lineAmount          Decimal @db.Decimal(12, 2)

  orderNo              String?  // 一次结账所有明细行共享此单号；null = 历史单行记录

  originalSaleRecordId String?
  refundedQty          Decimal? @db.Decimal(12, 2)
  refundReason         String?
  remark               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  store        Store    @relation(fields: [storeId], references: [id])
  operatorUser User     @relation(fields: [operatorUserId], references: [id])
  product      Product? @relation(fields: [productId], references: [id])

  originalSaleRecord SaleRecord?  @relation("RefundRelation", fields: [originalSaleRecordId], references: [id])
  refundChildren     SaleRecord[] @relation("RefundRelation")

  logs OperationLog[]

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([operatorUserId, createdAt])
  @@index([saleType, createdAt])
  @@index([originalSaleRecordId])
  @@index([barcode])
}

model MerchantPaymentConfig {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String?                    // null = tenant 级默认配置
  provider           String   @default("BAKONG_KHQR") // BAKONG_KHQR | ...
  merchantId         String
  merchantName       String
  merchantAccountRef String                     // Bakong 账户手机号 / ref
  currency           String   @default("USD")   // USD | KHR
  khqrEnabled        Boolean  @default(true)
  isDefault          Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  paymentIntents PaymentIntent[]

  @@index([tenantId])
  @@index([tenantId, storeId])
}

model PaymentIntent {
  id               String        @id @default(cuid())
  tenantId         String
  storeId          String
  operatorUserId   String
  orderNo          String        @unique
  paymentMethod    PaymentMethod
  status           PaymentStatus @default(PENDING)
  amount           Decimal       @db.Decimal(12, 2)
  khqrPayload      String?       // EMV QR string; null for CASH
  provider         String?       // from MerchantPaymentConfig.provider
  merchantConfigId String?       // FK to MerchantPaymentConfig
  paidAt           DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  merchantConfig MerchantPaymentConfig? @relation(fields: [merchantConfigId], references: [id])

  @@index([tenantId, createdAt])
  @@index([orderNo])
  @@index([status])
  @@index([merchantConfigId])
}

model BindToken {
  id        String   @id @default(cuid())
  token     String   @unique
  tenantId  String
  storeId   String
  role      UserRole
  label     String?          // 人工备注，如"总店员工邀请"
  expiresAt DateTime
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  status    String   @default("ACTIVE") // ACTIVE | REVOKED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId], references: [id])

  @@index([tenantId])
  @@index([token])
}

model OperationLog {
  id       String  @id @default(cuid())
  tenantId String
  storeId  String?
  userId   String?

  actionType      String
  targetType      String
  targetId        String?
  requestId       String?
  status          LogStatus
  message         String?
  payloadSnapshot Json?
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store? @relation(fields: [storeId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  saleRecordId String?
  saleRecord   SaleRecord? @relation(fields: [saleRecordId], references: [id])

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([userId, createdAt])
  @@index([requestId])
}

model TenantDailySummary {
  id           String   @id @default(cuid())
  date         String   // YYYY-MM-DD (UTC)
  tenantId     String
  salesCount   Int      @default(0)
  refundCount  Int      @default(0)
  grossSales   Decimal  @default(0) @db.Decimal(12, 2)
  refundAmount Decimal  @default(0) @db.Decimal(12, 2)
  netSales     Decimal  @default(0) @db.Decimal(12, 2)
  computedAt   DateTime @default(now())

  @@unique([tenantId, date])
  @@index([date])
}

model StoreDailySummary {
  id           String   @id @default(cuid())
  date         String   // YYYY-MM-DD (UTC)
  tenantId     String
  storeId      String
  salesCount   Int      @default(0)
  refundCount  Int      @default(0)
  grossSales   Decimal  @default(0) @db.Decimal(12, 2)
  refundAmount Decimal  @default(0) @db.Decimal(12, 2)
  netSales     Decimal  @default(0) @db.Decimal(12, 2)
  computedAt   DateTime @default(now())

  @@unique([storeId, date])
  @@index([tenantId, date])
}

model StoreApplication {
  id               String    @id @default(cuid())
  storeName        String
  ownerName        String
  telegramId       String
  telegramUsername String?
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt        DateTime  @default(now())
  approvedAt       DateTime?
  tenantId         String?   // set on approval
  bindTokenValue   String?   // set on approval, mirrors BindToken.token
  note             String?

  @@index([status])
  @@index([telegramId])
}

model TelegramMessage {
  id                  String   @id @default(cuid())
  tenantId            String?           // null = ops/系统级消息
  recipientTelegramId String            // 发件方(CUSTOMER)或收件方(OPS/SYSTEM)的 TG ID
  senderName          String?           // 客户名称，CUSTOMER 消息时填入
  messageType         String   @default("TEXT") // TEXT | IMAGE | STICKER | VOICE | VIDEO | FILE | OTHER
  content             String
  status              String   @default("SENT") // SENT | FAILED | RECEIVED
  errorMessage        String?
  sentBy              String   @default("SYSTEM") // SYSTEM | OPS | CUSTOMER
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@index([recipientTelegramId])
  @@index([createdAt])
}

model ProductImportSession {
  telegramId  String   @id
  tenantId    String?
  phase       String   @default("AWAITING_DATA") // AWAITING_DATA | AWAITING_CONFIRM
  pendingRows String   @default("[]")            // JSON — TgImportRow[]
  updatedAt   DateTime @updatedAt
}

model SupportSession {
  telegramId   String   @id
  tenantId     String?
  sessionState String   @default("auto_active") // auto_active | awaiting_human | human_active
  language     String   @default("zh")           // zh | en | km
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([sessionState])
}

model OpsAdmin {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String?  // scrypt hash; null = password login disabled
  telegramId   String?  @unique
  role         String   @default("OPS_ADMIN") // SUPER_ADMIN | OPS_ADMIN | BD
  status       String   @default("ACTIVE")    // ACTIVE | DISABLED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
